# Template for .env — copy to .env and fill in DD_API_KEY.
#   cp .env.example .env
# .env is git-ignored; .env.example is committed.

# Create a key: https://app.datadoghq.com/organization-settings/api-keys
DD_API_KEY=

# Datadog site. US1=datadoghq.com  US5=us5.datadoghq.com  EU=datadoghq.eu
#              US3=us3.datadoghq.com  AP1=ap1.datadoghq.com
DD_SITE=datadoghq.com

# Unified service tagging (env shared by agent + both backends)
DD_ENV=sandbox

# App version. Auto-set to the git short SHA by .githooks/pre-push on every push;
# falls back to "dev" if unset.
DD_VERSION=dev

# Optional
DD_HOSTNAME=griddog-sandbox
DD_TAGS=
